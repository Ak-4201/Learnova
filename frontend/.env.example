# Backend API base URL (no trailing slash).
# Use this when running frontend separately from backend (e.g. production or different ports).
# For local dev with Vite proxy, this is also used as the proxy target.
VITE_API_URL=http://localhost:8081

# Optional: URL to embed in the dashboard iframe after login (leave empty to hide).
# VITE_DASHBOARD_CONTENT_URL=https://example.com/your-page
